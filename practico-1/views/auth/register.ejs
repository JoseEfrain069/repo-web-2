<%- include('../components/header', { titulo: 'Registro' }) %>
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <h2 class="mb-3">Registro de Cliente</h2>
            <% if (error) { %>
                <div class="alert alert-danger">
                    <%= error %>
                </div>
                <% } %>
                    <form method="POST" action="/register" class="card card-body shadow-sm">
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" name="nombre" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contraseña</label>
                            <input type="password" name="contrasena" class="form-control" required>
                        </div>
                        <button class="btn btn-success">Crear cuenta</button>
                    </form>
                    <p class="mt-3">Ya tenes cuenta? <a href="/login">Ingresar</a></p>
        </div>
    </div>
    <%- include('../components/footer') %>