<%- include('../components/header', { titulo: 'Registro' }) %>
<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-3">Registro de Cliente</h2>
        <% if (error) { %>
            <div class="alert alert-secondary py-2">
                <%= error %>
            </div>
            <% } %>
                <form method="POST" action="/register">
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" name="nombre" class="form-control"
                            value="<%= valores && valores.nombre ? valores.nombre : '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control"
                            value="<%= valores && valores.email ? valores.email : '' %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contrasena</label>
                        <input type="password" name="contrasena" class="form-control" required>
                    </div>
                    <button class="btn btn-primary" type="submit">Guardar</button>
                </form>
                <p class="mt-3">Ya tenes cuenta? <a href="/login">Ingresar</a></p>
    </div>
</div>
<%- include('../components/footer') %>
