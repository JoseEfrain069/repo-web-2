<%- include('../components/header', { titulo: tipo ? 'Editar Tipo' : 'Nuevo Tipo' }) %>
<h2 class="mb-3"><%= tipo ? 'Editar Tipo' : 'Nuevo Tipo de Cancha' %></h2>
<form method="POST" action="<%= tipo ? '/admin/tipos/' + tipo.id + '/actualizar' : '/admin/tipos' %>">
    <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input type="text" name="nombre" class="form-control" value="<%= tipo ? tipo.nombre : '' %>" required>
    </div>
    <button class="btn btn-primary" type="submit">Guardar</button>
    <a href="/admin/tipos" class="btn btn-secondary">Cancelar</a>
</form>
<%- include('../components/footer') %>
