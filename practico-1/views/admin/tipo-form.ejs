<%- include('../components/header', { titulo: tipo ? 'Editar Tipo' : 'Nuevo Tipo' }) %>
    <h2 class="mb-3">
        <%= tipo ? 'Editar Tipo' : 'Nuevo Tipo de Cancha' %>
    </h2>
    <form class="card card-body" method="POST"
        action="<%= tipo ? '/admin/tipos/' + tipo.id + '/actualizar' : '/admin/tipos' %>">
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input type="text" name="nombre" class="form-control" value="<%= tipo ? tipo.nombre : '' %>" required>
        </div>
        <div>
            <button class="btn btn-success">Guardar</button>
            <a href="/admin/tipos" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
    <%- include('../components/footer') %>