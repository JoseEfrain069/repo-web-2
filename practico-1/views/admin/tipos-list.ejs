<%- include('../components/header', { titulo: 'Tipos de Cancha' }) %>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Tipos de Cancha</h2>
        <a href="/admin/tipos/nuevo" class="btn btn-primary">Nuevo tipo</a>
    </div>
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-striped m-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (!tipos.length) { %>
                        <tr>
                            <td colspan="3" class="text-center">Sin registros</td>
                        </tr>
                        <% } %>
                            <% tipos.forEach((tipo)=> { %>
                                <tr>
                                    <td>
                                        <%= tipo.id %>
                                    </td>
                                    <td>
                                        <%= tipo.nombre %>
                                    </td>
                                    <td>
                                        <a href="/admin/tipos/<%= tipo.id %>/editar"
                                            class="btn btn-sm btn-outline-secondary">Editar</a>
                                        <form action="/admin/tipos/<%= tipo.id %>/eliminar" method="POST"
                                            class="d-inline">
                                            <button class="btn btn-sm btn-outline-danger">Eliminar</button>
                                        </form>
                                    </td>
                                </tr>
                                <% }) %>
                </tbody>
            </table>
        </div>
    </div>
    <%- include('../components/footer') %>