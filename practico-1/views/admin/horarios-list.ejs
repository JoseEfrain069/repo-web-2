<%- include('../components/header', { titulo: 'Horarios' }) %>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Horarios de atencion</h2>
    <a href="/admin/horarios/nuevo" class="btn btn-primary">Agregar disponibilidad</a>
</div>

<form class="row g-2 mb-3" method="GET" action="/admin/horarios">
    <div class="col-md-5">
        <select class="form-select" name="cancha_id">
            <option value="">Todas las canchas</option>
            <% canchas.forEach((c)=> { %>
                <option value="<%= c.id %>" <%=filtros.cancha_id==c.id ? 'selected' : '' %>><%= c.nombre %></option>
                <% }) %>
        </select>
    </div>
    <div class="col-md-4">
        <input type="date" name="fecha" class="form-control" value="<%= filtros.fecha || '' %>">
    </div>
    <div class="col-md-3">
        <button class="btn btn-primary w-100" type="submit">Filtrar</button>
    </div>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Cancha</th>
            <th>Fecha</th>
            <th>Disponible desde</th>
            <th>Disponible hasta</th>
            <th>Disponible</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        <% if (!horarios.length) { %>
            <tr>
                <td colspan="6" class="text-center">Sin horarios</td>
            </tr>
            <% } %>
                <% horarios.forEach((h)=> { %>
                    <tr>
                        <td><%= h.cancha ? h.cancha.nombre : '-' %></td>
                        <td><%= h.fecha %></td>
                        <td><%= h.hora_inicio.slice(0, 5) %></td>
                        <td><%= h.hora_fin.slice(0, 5) %></td>
                        <td><%= h.disponible ? 'si' : 'no' %></td>
                        <td>
                            <form method="POST" action="/admin/horarios/<%= h.id %>/eliminar" class="d-inline">
                                <button class="btn btn-sm btn-danger" type="submit">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
    </tbody>
</table>
<%- include('../components/footer') %>
