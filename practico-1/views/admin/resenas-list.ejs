<%- include('../components/header', { titulo: 'Resenas' }) %>
<h2 class="mb-3">Resenas de Canchas</h2>
<form class="row g-2 mb-3" method="GET" action="/admin/resenas">
    <div class="col-md-9">
        <select name="cancha_id" class="form-select">
            <option value="">Todas las canchas</option>
            <% canchas.forEach((c)=> { %>
                <option value="<%= c.id %>" <%=cancha_id==c.id ? 'selected' : '' %>><%= c.nombre %></option>
                <% }) %>
        </select>
    </div>
    <div class="col-md-3">
        <button class="btn btn-primary w-100" type="submit">Filtrar</button>
    </div>
</form>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Cliente</th>
            <th>Cancha</th>
            <th>Puntaje</th>
            <th>Comentario</th>
        </tr>
    </thead>
    <tbody>
        <% if (!resenas.length) { %>
            <tr>
                <td colspan="4" class="text-center">Sin resenas</td>
            </tr>
            <% } %>
                <% resenas.forEach((r)=> { %>
                    <tr>
                        <td><%= r.usuario ? r.usuario.nombre : '-' %> (<%= r.usuario ? r.usuario.email : '-' %>)</td>
                        <td><%= r.cancha ? r.cancha.nombre : '-' %></td>
                        <td><%= r.calificacion %>/5</td>
                        <td><%= r.comentario %></td>
                    </tr>
                    <% }) %>
    </tbody>
</table>
<%- include('../components/footer') %>
