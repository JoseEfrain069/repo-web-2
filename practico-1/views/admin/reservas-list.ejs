<%- include('../components/header', { titulo: 'Reservas' }) %>
<h2 class="mb-3">Todas las Reservas</h2>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Cliente</th>
            <th>Email</th>
            <th>Cancha</th>
            <th>Fecha</th>
            <th>Horario</th>
            <th>Estado</th>
            <th>Actualizar</th>
        </tr>
    </thead>
    <tbody>
        <% if (!reservas.length) { %>
            <tr>
                <td colspan="7" class="text-center">Sin reservas</td>
            </tr>
            <% } %>
                <% reservas.forEach((r)=> { %>
                    <tr>
                        <td><%= r.usuario ? r.usuario.nombre : '-' %></td>
                        <td><%= r.usuario ? r.usuario.email : '-' %></td>
                        <td><%= r.horario && r.horario.cancha ? r.horario.cancha.nombre : '-' %></td>
                        <td><%= r.horario ? r.horario.fecha : '-' %></td>
                        <td><%= r.horario ? r.horario.hora_inicio : '-' %> - <%= r.horario ? r.horario.hora_fin : '-' %></td>
                        <td><%= r.estado %></td>
                        <td>
                            <form method="POST" action="/admin/reservas/<%= r.id %>/estado" class="row g-1">
                                <div class="col">
                                    <select name="estado" class="form-select form-select-sm">
                                        <option value="confirmada" <%=r.estado==='confirmada' ? 'selected' : '' %>>confirmada</option>
                                        <option value="cancelada" <%=r.estado==='cancelada' ? 'selected' : '' %>>cancelada</option>
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-sm btn-primary" type="submit">Guardar</button>
                                </div>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
    </tbody>
</table>
<%- include('../components/footer') %>
