<%- include('../components/header', { titulo: 'Canchas Disponibles' }) %>
<h2 class="mb-3">Canchas Disponibles</h2>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Tipo</th>
            <th>Precio</th>
            <th>Accion</th>
        </tr>
    </thead>
    <tbody>
        <% if (!canchas.length) { %>
            <tr>
                <td colspan="4" class="text-center">No hay canchas activas</td>
            </tr>
            <% } %>
                <% canchas.forEach((cancha)=> { %>
                    <tr>
                        <td><%= cancha.nombre %></td>
                        <td><%= cancha.tipo ? cancha.tipo.nombre : 'Sin tipo' %></td>
                        <td>$<%= cancha.precio_por_hora %></td>
                        <td>
                            <a class="btn btn-sm btn-primary" href="/canchas/<%= cancha.id %>">Ver horarios</a>
                        </td>
                    </tr>
                    <% }) %>
    </tbody>
</table>
<%- include('../components/footer') %>
