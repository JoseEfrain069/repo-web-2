<%- include('../components/header', { titulo: 'Canchas Disponibles' }) %>
    <h2 class="mb-4">Canchas Disponibles</h2>
    <div class="row g-3">
        <% if (!canchas.length) { %>
            <div class="col-12">
                <div class="alert alert-info">No hay canchas activas.</div>
            </div>
            <% } %>
                <% canchas.forEach((cancha)=> { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">
                                    <%= cancha.nombre %>
                                </h5>
                                <p class="mb-1"><strong>Tipo:</strong>
                                    <%= cancha.tipo ? cancha.tipo.nombre : 'Sin tipo' %>
                                </p>
                                <p><strong>Precio/hora:</strong> $<%= cancha.precio_por_hora %>
                                </p>
                                <a class="btn btn-primary mt-auto" href="/canchas/<%= cancha.id %>">Ver
                                    disponibilidad</a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
    </div>
    <%- include('../components/footer') %>