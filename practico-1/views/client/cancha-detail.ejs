<%- include('../components/header', { titulo: cancha.nombre }) %>
<h2><%= cancha.nombre %></h2>
<p>Tipo: <%= cancha.tipo ? cancha.tipo.nombre : 'Sin tipo' %></p>
<p>Precio por hora: $<%= cancha.precio_por_hora %></p>
<p><a href="/canchas">Volver</a></p>

<form class="row g-2 mb-3" method="GET" action="/canchas/<%= cancha.id %>">
    <div class="col-md-4">
        <label class="form-label">Fecha</label>
        <input type="date" name="fecha" class="form-control" value="<%= fechaSeleccionada %>" min="<%= hoy %>" required>
    </div>
    <div class="col-md-2">
        <label class="form-label">&nbsp;</label>
        <button class="btn btn-primary w-100" type="submit">Buscar</button>
    </div>
</form>

<h3>Fechas con horarios disponibles</h3>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Horas libres</th>
            <th>Accion</th>
        </tr>
    </thead>
    <tbody>
        <% if (!fechasDisponibles.length) { %>
            <tr>
                <td colspan="3" class="text-center">No hay fechas disponibles</td>
            </tr>
            <% } %>
                <% fechasDisponibles.forEach((item)=> { %>
                    <tr>
                        <td><%= item.fecha %></td>
                        <td><%= item.cantidad %></td>
                        <td>
                            <a href="/canchas/<%= cancha.id %>?fecha=<%= item.fecha %>" class="btn btn-sm btn-primary">Ver</a>
                        </td>
                    </tr>
                    <% }) %>
    </tbody>
</table>

<h3>Horarios disponibles</h3>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Inicio</th>
            <th>Fin</th>
            <th>Accion</th>
        </tr>
    </thead>
    <tbody>
        <% if (!horarios.length) { %>
            <tr>
                <td colspan="3" class="text-center">No hay horarios disponibles</td>
            </tr>
            <% } %>
                <% horarios.forEach((h)=> { %>
                    <tr>
                        <td><%= h.hora_inicio %></td>
                        <td><%= h.hora_fin %></td>
                        <td>
                            <form action="/reservas" method="POST" class="m-0">
                                <input type="hidden" name="horario_id" value="<%= h.id %>">
                                <button class="btn btn-sm btn-primary" type="submit">Reservar</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
    </tbody>
</table>

<h3>Resenas</h3>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Usuario</th>
            <th>Puntaje</th>
            <th>Comentario</th>
        </tr>
    </thead>
    <tbody>
        <% if (!resenas.length) { %>
            <tr>
                <td colspan="3" class="text-center">Todavia no hay resenas</td>
            </tr>
            <% } %>
                <% resenas.forEach((r)=> { %>
                    <tr>
                        <td><%= r.usuario ? r.usuario.nombre : 'Usuario' %></td>
                        <td><%= r.calificacion %>/5</td>
                        <td><%= r.comentario %></td>
                    </tr>
                    <% }) %>
    </tbody>
</table>
<%- include('../components/footer') %>
