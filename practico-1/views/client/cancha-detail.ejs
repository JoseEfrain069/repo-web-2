<%- include('../components/header', { titulo: cancha.nombre }) %>
<h2><%= cancha.nombre %></h2>
<p>Tipo: <%= cancha.tipo ? cancha.tipo.nombre : 'Sin tipo' %></p>
<p>Precio por hora: $<%= cancha.precio_por_hora %></p>
<p><a href="/canchas">Volver</a></p>

<form class="row g-2 mb-3" method="GET" action="/canchas/<%= cancha.id %>">
    <div class="col-md-4">
        <label class="form-label">Fecha</label>
        <input type="date" name="fecha" class="form-control" value="<%= fechaSeleccionada %>" min="<%= hoy %>" required>
    </div>
    <div class="col-md-2">
        <label class="form-label">&nbsp;</label>
        <button class="btn btn-primary w-100" type="submit">Buscar</button>
    </div>
</form>

<h3>Rangos disponibles del dia</h3>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Inicio</th>
            <th>Fin</th>
        </tr>
    </thead>
    <tbody>
        <% if (!horarios.length) { %>
            <tr>
                <td colspan="2" class="text-center">No hay horarios disponibles</td>
            </tr>
            <% } %>
                <% horarios.forEach((h)=> { %>
                    <tr>
                        <td><%= h.hora_inicio.slice(0, 5) %></td>
                        <td><%= h.hora_fin.slice(0, 5) %></td>
                    </tr>
                    <% }) %>
    </tbody>
</table>

<h3>Crear reserva</h3>
<% if (horarios.length) { %>
    <form action="/reservas" method="POST" class="row g-2 mb-4">
        <input type="hidden" name="cancha_id" value="<%= cancha.id %>">
        <input type="hidden" name="fecha" value="<%= fechaSeleccionada %>">
        <div class="col-md-3">
            <label class="form-label">Hora inicio</label>
            <input type="time" name="hora_inicio" class="form-control" required>
        </div>
        <div class="col-md-3">
            <label class="form-label">Hora fin</label>
            <input type="time" name="hora_fin" class="form-control" required>
        </div>
        <div class="col-md-3">
            <label class="form-label">&nbsp;</label>
            <button class="btn btn-primary w-100" type="submit">Reservar</button>
        </div>
    </form>
    <% } else { %>
        <p>No podes reservar porque ese dia no tiene disponibilidad.</p>
        <% } %>

<h3>Resenas</h3>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Usuario</th>
            <th>Puntaje</th>
            <th>Comentario</th>
        </tr>
    </thead>
    <tbody>
        <% if (!resenas.length) { %>
            <tr>
                <td colspan="3" class="text-center">Todavia no hay resenas</td>
            </tr>
            <% } %>
                <% resenas.forEach((r)=> { %>
                    <tr>
                        <td><%= r.usuario ? r.usuario.nombre : 'Usuario' %></td>
                        <td><%= r.calificacion %>/5</td>
                        <td><%= r.comentario %></td>
                    </tr>
                    <% }) %>
    </tbody>
</table>
<%- include('../components/footer') %>
